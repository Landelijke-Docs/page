{"title":"Upload Form","markdown":{"yaml":{"title":"Upload Form","format":"html"},"containsRefs":false,"markdown":"\n\n<style>\n    body {\n        font-family: Verdana, sans-serif;\n        background-color: #f4f4f4;\n        padding: 20px;\n    }\n\n    form {\n        background-color: #fff;\n        padding: 20px;\n        border-radius: 8px;\n        box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        max-width: 600px;\n        margin: auto;\n    }\n\n    label {\n        display: block;\n        margin-bottom: 8px;\n        font-weight: bold;\n    }\n\n    input[type=\"text\"],\n    input[type=\"email\"],\n    input[type=\"file\"],\n    textarea {\n        width: 100%;\n        padding: 10px;\n        margin-bottom: 15px;\n        border: 1px solid #ccc;\n        border-radius: 4px;\n        font-size: 16px;\n    }\n\n    input[type=\"radio\"],\n    input[type=\"checkbox\"] {\n        margin-right: 10px;\n    }\n\n    input[type=\"submit\"] {\n        background-color: #007BFF;\n        color: white;\n        padding: 12px 20px;\n        border: none;\n        border-radius: 4px;\n        font-size: 16px;\n        cursor: pointer;\n        width: 100%;\n    }\n\n    input[type=\"submit\"]:hover {\n        background-color: #0056b3;\n    }\n</style>\n\n<form id=\"uploadForm\">\n    <label for=\"name\">Name:</label><br>\n    <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"Enter your name\"><br>\n\n    <label for=\"email\">Email:</label><br>\n    <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"Enter your email\"><br>\n\n    <label for=\"gender\">Gender:</label><br>\n    <input type=\"radio\" id=\"male\" name=\"gender\" value=\"male\">\n    <label for=\"male\">Male</label><br>\n    <input type=\"radio\" id=\"female\" name=\"gender\" value=\"female\">\n    <label for=\"female\">Female</label><br>\n    <input type=\"radio\" id=\"other\" name=\"gender\" value=\"other\">\n    <label for=\"other\">Other</label><br>\n\n    <label for=\"interests\">Interests:</label><br>\n    <input type=\"checkbox\" id=\"interest1\" name=\"interests\" value=\"reading\">\n    <label for=\"interest1\">Reading</label><br>\n    <input type=\"checkbox\" id=\"interest2\" name=\"interests\" value=\"coding\">\n    <label for=\"interest2\">Coding</label><br>\n    <input type=\"checkbox\" id=\"interest3\" name=\"interests\" value=\"music\">\n    <label for=\"interest3\">Music</label><br>\n\n    <label for=\"file\">Upload File:</label><br>\n    <input type=\"file\" id=\"file\" name=\"file\"><br>\n\n    <button type=\"button\" onclick=\"submitForm()\">Submit</button>\n</form>\n\n<script>\n    function submitForm() {\n        const formData = new FormData(document.getElementById(\"uploadForm\"));\n        fetch(\"https://your-ovh-api-url.com/upload\", {\n        method: \"POST\",\n        body: formData\n        })\n        .then(response => response.json())\n        .then(data => {\n        console.log(\"Success:\", data);\n        })\n        .catch(error => {\n        console.error(\"Error:\", error);\n        });\n    }\n</script>","srcMarkdownNoYaml":"\n\n<style>\n    body {\n        font-family: Verdana, sans-serif;\n        background-color: #f4f4f4;\n        padding: 20px;\n    }\n\n    form {\n        background-color: #fff;\n        padding: 20px;\n        border-radius: 8px;\n        box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        max-width: 600px;\n        margin: auto;\n    }\n\n    label {\n        display: block;\n        margin-bottom: 8px;\n        font-weight: bold;\n    }\n\n    input[type=\"text\"],\n    input[type=\"email\"],\n    input[type=\"file\"],\n    textarea {\n        width: 100%;\n        padding: 10px;\n        margin-bottom: 15px;\n        border: 1px solid #ccc;\n        border-radius: 4px;\n        font-size: 16px;\n    }\n\n    input[type=\"radio\"],\n    input[type=\"checkbox\"] {\n        margin-right: 10px;\n    }\n\n    input[type=\"submit\"] {\n        background-color: #007BFF;\n        color: wh